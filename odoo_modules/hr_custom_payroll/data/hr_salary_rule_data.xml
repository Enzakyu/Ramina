<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================ -->
        <!-- Salary Rule Category: Overtime                                -->
        <!-- ============================================================ -->
        <record id="hr_salary_rule_category_overtime" model="hr.salary.rule.category">
            <field name="name">Overtime</field>
            <field name="code">OVT</field>
            <field name="note">Overtime bonus payments for hours worked beyond standard schedule</field>
        </record>

        <!-- ============================================================ -->
        <!-- Salary Rule: Overtime Bonus                                   -->
        <!-- ============================================================ -->
        <record id="hr_salary_rule_overtime_bonus" model="hr.salary.rule">
            <field name="name">Overtime Bonus</field>
            <field name="code">OVERTIME_BONUS</field>
            <field name="sequence">150</field>
            <field name="category_id" ref="hr_salary_rule_category_overtime"/>
            <field name="condition_select">python</field>
            <field name="condition_python">
result = bool(payslip.overtime_bonus_ids)
            </field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = sum(payslip.overtime_bonus_ids.mapped('bonus_amount'))
            </field>
            <field name="note">
Automatic overtime bonus calculation:
- Based on hours worked beyond 8-hour standard (9 AM - 5 PM)
- Rate: 1.5x hourly wage (derived from monthly contract wage / 173 avg hours)
- Only confirmed overtime records are included
            </field>
            <field name="appears_on_payslip">True</field>
        </record>

    </data>
</odoo>
